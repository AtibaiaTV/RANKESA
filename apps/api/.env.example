NODE_ENV=development
PORT=3001

MONGODB_URI=mongodb://localhost:27017/tennis-rank

JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d

CORS_ORIGINS=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rank.app

APP_URL=http://localhost:3000

# Horas até auto-confirmar resultado não disputado
AUTO_CONFIRM_HOURS=48

# ── Asaas (gateway de pagamento PIX) ──
# Obtenha em: https://app.asaas.com → Configurações → Integrações → API
ASAAS_API_KEY=
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token para validar chamadas de webhook recebidas do Asaas
ASAAS_WEBHOOK_TOKEN=
